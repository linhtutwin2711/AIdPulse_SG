    {
      "parameters": {
        "jsCode": "// data.gov.sg NEA Dengue Clusters (GeoJSON) -> case_clusters rows.\n// Each cluster: LOCALITY -> area, CASE_SIZE -> active_cases, polygon centroid\n// -> lat/lng, OBJECTID -> stable source_id (upsert key). The biggest cluster\n// is flagged as the dashboard banner.\nlet raw = $input.first().json;\nlet gj = raw;\nif (typeof raw === 'string') gj = JSON.parse(raw);\nelse if (raw && typeof raw.data === 'string') gj = JSON.parse(raw.data);\nelse if (raw && typeof raw.body === 'string') gj = JSON.parse(raw.body);\nelse if (raw && raw.body) gj = raw.body;\nfunction centroid(geom){\n  if(!geom) return [null,null];\n  let ring = geom.type==='Polygon' ? geom.coordinates[0]\n           : geom.type==='MultiPolygon' ? geom.coordinates[0][0] : null;\n  if(!ring || !ring.length) return [null,null];\n  let sx=0, sy=0; for(const p of ring){ sx+=p[0]; sy+=p[1]; }\n  return [sy/ring.length, sx/ring.length]; // lat, lng\n}\nfunction titleCase(s){ return s.replace(/\\b\\w/g, c => c.toUpperCase()); }\nconst rows = [];\nfor (const f of (gj.features || [])) {\n  const p = f.properties || {};\n  const loc = (p.LOCALITY || '').trim();\n  let cases = parseInt(p.CASE_SIZE, 10); if (isNaN(cases)) cases = 0;\n  const [lat, lng] = centroid(f.geometry);\n  if (!loc || lat === null) continue;\n  const name = titleCase(loc);\n  const risk = cases >= 50 ? 'critical' : cases >= 10 ? 'high' : 'medium';\n  rows.push({\n    disease: 'dengue',\n    title: 'Dengue cluster at ' + name,\n    description: cases + ' active dengue case(s) reported by NEA at ' + name + '.',\n    area_name: name,\n    latitude: Math.round(lat * 1e6) / 1e6,\n    longitude: Math.round(lng * 1e6) / 1e6,\n    active_cases: cases,\n    critical_cases: cases >= 10 ? cases : 0,\n    risk_level: risk,\n    is_banner: false,\n    source_id: 'nea-dengue-' + p.OBJECTID\n  });\n}\nif (rows.length) {\n  let ti = 0;\n  for (let i = 1; i < rows.length; i++) if (rows[i].active_cases > rows[ti].active_cases) ti = i;\n  rows[ti].is_banner = true;\n}\nreturn [{ json: { rows } }];"
      },
      "id": "ee071f0e-f685-4bec-bfe9-0f2524c6fc6b",
      "name": "Build case_clusters rows · Cases Ingest",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        3220
      ]
    },
