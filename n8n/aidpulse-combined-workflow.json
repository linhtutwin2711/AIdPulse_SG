        "jsCode": "// Trusted, public health / pandemic RSS sources (real article URLs + real\n// article photos via og:image). Add more health feeds freely.\nreturn [\n  { json: { url: 'https://www.who.int/rss-feeds/news-english.xml' } },\n  { json: { url: 'https://news.un.org/feed/subscribe/en/news/topic/health/feed/rss.xml' } }\n];"
